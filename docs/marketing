<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Fall, Number… Fall!</title>
  <style>
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: radial-gradient(circle at top left, #ff4f8b33, transparent 30%),
                  radial-gradient(circle at top right, #24c6dc33, transparent 30%),
                  linear-gradient(135deg, #fff4dc, #f2d6a2);
      color: #3a2418;
    }
    main {
      max-width: 900px;
      margin: 0 auto;
      padding: 56px 24px;
      text-align: center;
    }
    .icon {
      width: 128px;
      height: 128px;
      margin: 0 auto 28px;
      border-radius: 32px;
      background: linear-gradient(135deg, #ff9f1c, #ff4f8b, #7b61ff, #24c6dc);
      display: grid;
      place-items: center;
      color: white;
      font-size: 42px;
      font-weight: 900;
      box-shadow: 0 24px 60px rgba(58,36,24,.22);
    }
    h1 {
      font-size: clamp(42px, 7vw, 72px);
      margin: 0;
      letter-spacing: -0.06em;
      line-height: .95;
    }
    .subtitle {
      font-size: 22px;
      font-weight: 800;
      margin-top: 18px;
    }
    p {
      font-size: 18px;
      line-height: 1.55;
      color: rgba(58,36,24,.78);
      max-width: 680px;
      margin: 16px auto;
    }
    .badges {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 10px;
      margin: 28px 0;
    }
    .badge {
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(255,255,255,.62);
      border: 1px solid rgba(58,36,24,.14);
      font-weight: 800;
    }
    .cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin-top: 32px;
    }
    .card {
      background: rgba(255,255,255,.62);
      border: 1px solid rgba(58,36,24,.14);
      border-radius: 24px;
      padding: 22px;
      box-shadow: 0 18px 50px rgba(58,36,24,.10);
    }
    .card h2 {
      margin: 0 0 8px;
      font-size: 21px;
    }
    .card p {
      font-size: 15px;
      margin: 0;
    }
    .footer {
      margin-top: 42px;
      font-size: 14px;
      color: rgba(58,36,24,.62);
    }
    a {
      color: #7b61ff;
      font-weight: 800;
      text-decoration: none;
    }
    @media (max-width: 760px) {
      .cards { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <main>
    <div class="icon">FNF</div>

    <h1>Fall, Number… Fall!</h1>
    <div class="subtitle">Colorful addition puzzle game</div>

    <p>
      Make horizontal and vertical sums, clear the board, and learn addition through playful falling-number challenges.
    </p>

    <div class="badges">
      <span class="badge">Beginner Mode</span>
      <span class="badge">Expert Mode</span>
      <span class="badge">Power-Ups</span>
      <span class="badge">Perfect Clears</span>
    </div>

    <section class="cards">
      <div class="card">
        <h2>Drop numbers</h2>
        <p>Move falling tiles left or right and place them smartly.</p>
      </div>

      <div class="card">
        <h2>Make sums</h2>
        <p>Create horizontal or vertical lines that match the target.</p>
      </div>

      <div class="card">
        <h2>Clear the board</h2>
        <p>Use cascades and power-ups to chase your best score.</p>
      </div>
    </section>

    <p>
      Designed for quick thinking, colorful play, and simple addition practice.
    </p>

    <div class="footer">
      <p>
        Support:
        <a href="mailto:stanko.gazibaric@gmail.com">stanko.gazibaric@gmail.com</a>
      </p>
      <p>© 2026 Stanko Gazibaric</p>
    </div>
  </main>
</body>
</html>
